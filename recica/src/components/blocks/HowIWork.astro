---
import { principles, sectionCopy } from '@/lib/site-content';
---

<section id="about" class="section-shell anchor-target">
	<div class="section-grid">
		<div class="section-heading-block">
			<p class="kicker">{sectionCopy.about.kicker}</p>
			<h2 class="section-title">{sectionCopy.about.title}</h2>
			<p class="section-copy">{sectionCopy.about.description}</p>
		</div>

		<div class="principle-list">
			{
				principles.map((principle) => (
					<article class="principle-item">
						<h3>{principle.title}</h3>
						<p>{principle.description}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
