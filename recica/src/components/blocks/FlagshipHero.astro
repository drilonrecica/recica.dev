---
import { heroActions, sectionCopy, siteConfig } from '@/lib/site-content';

const posterLines = [
	'Android delivery',
	'Systems modernization',
	'Product judgment',
	'Independent tools'
];
---

<section class="hero-stage">
	<div class="hero-stage__wash" aria-hidden="true"></div>
	<div class="hero-stage__shell">
		<div class="hero-copy">
			<h1 class="hero-title">{siteConfig.name}</h1>
			<p class="hero-role">{siteConfig.role}</p>
			<p class="hero-support">{siteConfig.supportingLine}</p>
			<p class="hero-intro">{sectionCopy.hero.intro}</p>

			<div class="hero-actions" aria-label="Primary actions">
				{
					heroActions.map((action) => (
						<a
							href={action.href}
							class={`action-link action-link--${action.style ?? 'text'}`}
							target={action.external ? '_blank' : undefined}
							rel={action.external ? 'noreferrer' : undefined}
						>
							{action.label}
						</a>
					))
				}
			</div>
		</div>

		<div class="hero-poster" aria-hidden="true">
			<div class="hero-poster__frame">
				<div class="hero-poster__mesh"></div>
				<div class="hero-poster__route hero-poster__route--primary"></div>
				<div class="hero-poster__route hero-poster__route--secondary"></div>
				<div class="hero-poster__route hero-poster__route--tertiary"></div>
				<div class="hero-poster__route hero-poster__route--quaternary"></div>
				<div class="hero-poster__node hero-poster__node--origin"></div>
				<div class="hero-poster__node hero-poster__node--switch"></div>
				<div class="hero-poster__node hero-poster__node--target"></div>
				<div class="hero-poster__signal hero-poster__signal--north">Production Android</div>
				<div class="hero-poster__signal hero-poster__signal--east">Systems work</div>
				<div class="hero-poster__signal hero-poster__signal--south">Product delivery</div>
				<div class="hero-poster__kicker">Mobile / Product / Systems</div>
				<div class="hero-poster__stack">
					{
						posterLines.map((line) => (
							<p>{line}</p>
						))
					}
				</div>
				<div class="hero-poster__footer">
					<span>Selected work</span>
					<span>Independent tools</span>
					<span>Clear contact</span>
				</div>
			</div>
		</div>
	</div>
</section>
