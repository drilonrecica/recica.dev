---
import { caseStudies, sectionCopy } from '@/lib/site-content';
---

<section id="work" class="section-shell anchor-target">
	<div class="section-heading-block">
		<p class="kicker">{sectionCopy.work.kicker}</p>
		<h2 class="section-title">{sectionCopy.work.title}</h2>
		<p class="section-copy">{sectionCopy.work.description}</p>
	</div>

	<div class="story-list">
		{
			caseStudies.map((study) => (
				<article class={`story-row story-row--${study.tone}`}>
					<div class="story-row__meta">
						<div>
							<p class="story-row__eyebrow">{study.period}</p>
							<h3 class="story-row__title">{study.title}</h3>
							<p class="story-row__role">{study.role}</p>
						</div>
						<a href={study.href} target="_blank" rel="noreferrer" class="story-row__link">
							{study.linkLabel}
						</a>
					</div>

					<div class="story-row__body">
						<p class="story-row__summary">{study.summary}</p>
						<ul class="story-row__bullets">
							{
								study.bullets.map((bullet) => (
									<li>{bullet}</li>
								))
							}
						</ul>
						<p class="story-row__outcome">
							<span>Outcome</span>
							{study.outcome}
						</p>
						<div class="tag-row">
							{
								study.stack.map((tag) => (
									<span>{tag}</span>
								))
							}
						</div>
					</div>
				</article>
			))
		}
	</div>
</section>
