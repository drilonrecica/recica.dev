---
import { experienceItems, sectionCopy, siteConfig } from '@/lib/site-content';
---

<section id="experience" class="section-shell anchor-target">
	<div class="section-grid">
		<div class="section-heading-block">
			<p class="kicker">{sectionCopy.experience.kicker}</p>
			<h2 class="section-title">{sectionCopy.experience.title}</h2>
			<p class="section-copy">{sectionCopy.experience.description}</p>
			<a href={siteConfig.cvPath} class="action-link action-link--text">Download the full CV</a>
		</div>

		<div class="timeline-list">
			{
				experienceItems.map((item) => (
					<article class="timeline-item">
						<p class="timeline-item__period">{item.period}</p>
						<div>
							<h3>{item.title}</h3>
							<p class="timeline-item__role">{item.role}</p>
							<p class="timeline-item__summary">{item.summary}</p>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>
