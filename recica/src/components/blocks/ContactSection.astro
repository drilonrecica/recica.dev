---
import { contactLinks, sectionCopy, siteConfig } from '@/lib/site-content';
---

<section id="contact" class="section-shell anchor-target">
	<div class="section-grid">
		<div class="section-heading-block">
			<p class="kicker">{sectionCopy.contact.kicker}</p>
			<h2 class="section-title">{sectionCopy.contact.title}</h2>
			<p class="section-copy">{sectionCopy.contact.description}</p>
			<p class="contact-address">
				{sectionCopy.contact.emailLabel}:
				<a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
			</p>
		</div>

		<div class="contact-list">
			{
				contactLinks.map((link) => (
					<a
						href={link.href}
						class={`contact-item${link.primary ? ' contact-item--primary' : ''}${link.subdued ? ' contact-item--subdued' : ''}`}
						target={link.href.startsWith('http') ? '_blank' : undefined}
						rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
					>
						<p class="contact-item__eyebrow">{link.eyebrow}</p>
						<h3>{link.label}</h3>
						<p>{link.description}</p>
					</a>
				))
			}
		</div>
	</div>
</section>
