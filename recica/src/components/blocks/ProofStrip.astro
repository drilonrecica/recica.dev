---
import { proofItems, sectionCopy } from '@/lib/site-content';
---

<section class="section-shell section-shell--tight">
	<div class="section-grid">
		<div class="section-heading-block">
			<p class="kicker">{sectionCopy.proof.kicker}</p>
			<h2 class="section-title">{sectionCopy.proof.title}</h2>
			<p class="section-copy">{sectionCopy.proof.description}</p>
		</div>

		<div class="proof-grid">
			{
				proofItems.map((item) => (
					<article class="proof-item">
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
