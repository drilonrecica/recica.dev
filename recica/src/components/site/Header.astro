---
import { navigation, siteConfig } from "@/lib/site-content";

---

<header class="site-header" data-scrolled="false">
    <div class="site-header__shell">
        <a
            href="/"
            class="site-brand"
            aria-label="recica.dev home"
        >
            {siteConfig.domain}
        </a>

        <nav class="site-nav" aria-label="Primary">
            <div class="site-nav__links">
                {
                    navigation.map((item) => (
                        <a href={item.href}>{item.label}</a>
                    ))
                }
            </div>
            <div class="site-nav__utilities">
                <a href={siteConfig.cvPath} class="utility-link">CV</a>
                <a href={`mailto:${siteConfig.email}`} class="utility-link utility-link--strong">Email</a>
            </div>
        </nav>

        <details class="site-nav-mobile">
            <summary
                class="site-nav-mobile__summary"
                aria-label="Open navigation"
            >
                Menu
            </summary>
            <div class="site-nav-mobile__panel">
                {
                    navigation.map((item) => (
                        <a href={item.href}>{item.label}</a>
                    ))
                }
                <a href={siteConfig.cvPath}>Download CV</a>
                <a href={`mailto:${siteConfig.email}`}>Email</a>
            </div>
        </details>
    </div>
</header>

<script>
    const header = document.querySelector(".site-header");

    const syncHeaderState = () => {
        if (!header) return;
        header.setAttribute("data-scrolled", window.scrollY > 24 ? "true" : "false");
    };

    syncHeaderState();
    window.addEventListener("scroll", syncHeaderState, { passive: true });
</script>
